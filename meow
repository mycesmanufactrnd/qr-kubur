server {
    listen 80;
    server_name qubur.mycesgroup.com;

    access_log logs/qubur.access.log;
    error_log logs/qubur.error.log warn;

    # ACME challenge for Let's Encrypt
    location ^~ /.well-known/acme-challenge/ {
        root C:/cert/acme-webroot;
        default_type text/plain;
        allow all;
    }

    # Redirect all other HTTP requests to HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    server_name qubur.mycesgroup.com;

    access_log logs/qubur.access.log;
    error_log logs/qubur.error.log warn;

    ssl_certificate     C:/cert/qubur.mycesgroup.com/qubur.mycesgroup.com-chain.pem;
    ssl_certificate_key C:/cert/qubur.mycesgroup.com/qubur.mycesgroup.com-key.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    # tRPC endpoint
    location /trpc/ {
        proxy_pass http://127.0.0.1:8083;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Other API routes
    location /api/ {
        proxy_pass http://127.0.0.1:8083;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Frontend SPA
    location / {
        root C:/Website/qr-kubur/dist;
        index index.html;
        try_files $uri $uri/ /index.html;

        # --- Security headers (Security Headers / snyk scan) ---
        set $csp "default-src 'self'; ";
        set $csp "${csp}script-src 'self' https://mymeet.quezera.xyz; ";
        set $csp "${csp}style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; ";
        set $csp "${csp}font-src 'self' data: https://fonts.gstatic.com; ";
        set $csp "${csp}img-src 'self' data: blob: https://tile.openstreetmap.org https://raw.githubusercontent.com https://unpkg.com https://mymeet.quezera.xyz; ";
        set $csp "${csp}connect-src 'self' https://firebaseinstallations.googleapis.com https://fcmregistrations.googleapis.com https://fcm.googleapis.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://mymeet.quezera.xyz wss://mymeet.quezera.xyz; ";
        set $csp "${csp}frame-src 'self' https://mymeet.quezera.xyz; ";
        set $csp "${csp}worker-src 'self'; ";
        set $csp "${csp}manifest-src 'self'; ";
        set $csp "${csp}object-src 'none'; ";
        set $csp "${csp}base-uri 'self'; ";
        set $csp "${csp}frame-ancestors 'none'; ";
        set $csp "${csp}form-action 'self';";

        add_header Content-Security-Policy $csp always;
        add_header X-Frame-Options "DENY" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
        add_header Permissions-Policy "geolocation=(self), camera=(self \"https://mymeet.quezera.xyz\"), microphone=(self \"https://mymeet.quezera.xyz\"), payment=(), usb=()" always;
    }

    # Error page
    error_page 500 502 503 504 /50x.html;
    location = /50x.html {
        root html;
    }
}

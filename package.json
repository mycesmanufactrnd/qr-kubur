{
  "name": "qr-kubur",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p ./jsconfig.json",
    "preview": "vite preview",
    "docker:rebuild:all": "docker compose --env-file .env down -v --remove-orphans && docker compose --env-file .env up -d --build",
    "docker:up": "docker compose --env-file .env up -d",
    "docker:down": "docker compose --env-file .env down",
    "docker:down:volume": "docker compose --env-file .env down -v",
    "docker:restart": "npm run docker:down && npm run docker:up && npm run docker:logs:backend",
    "docker:restart:dev": "docker compose up -d --force-recreate backend frontend",
    "docker:rebuild:dev": "docker compose build backend frontend && docker compose up -d backend frontend",
    "docker:rebuild:backend": "docker compose stop backend && docker compose rm -f backend && docker volume rm qr-kubur_backend_node_modules && docker compose build backend && docker compose up -d backend && docker compose logs -f backend",
    "docker:logs": "docker compose --env-file .env logs -f",
    "docker:logs:backend": "docker compose --env-file .env logs -f backend",
    "docker:logs:frontend": "docker compose --env-file .env logs -f frontend",
    "docker:restart:dev:logs": "npm run docker:restart:dev && npm run docker:logs:backend",
    "docker:supabase": "docker exec -it supabase_db psql -U postgres -d supabase",
    "docker:seed": "docker compose exec backend npm run seed",
    "docker:seed:prod": "docker compose exec backend npm run seed:prod"
  },

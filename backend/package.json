{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts --poll 1000",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "tsx src/db/seed.js",
    "seed:prod": "tsx src/db/seed.prod.js",
    "typeorm": "typeorm-ts-node-esm",
    "migration:create": "npm run typeorm -- migration:create",
    "migration:generate": "npm run typeorm -- migration:generate --dataSource ./src/datasource.js",
    "migration:run": "npm run typeorm -- migration:run --dataSource src/datasource.js",
    "migration:revert": "npm run typeorm -- migration:revert --dataSource src/datasource.js"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^9.3.0",
    "@fastify/rate-limit": "^10.3.0",
    "@trpc/server": "^11.8.1",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "chokidar": "^5.0.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "firebase-admin": "^13.8.0",
    "google-auth-library": "^10.5.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "moment-hijri": "^3.0.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "xlsx": "^0.18.5",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.3",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typeorm-ts-node-esm": "^0.3.20",
    "typescript": "^5.9.3"
  }
}

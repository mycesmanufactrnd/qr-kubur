# =========================================================================
# GENERAL / SHARED CONFIG
# =========================================================================

PROJECT_ID=supabase-local
DATABASE_SYNC=true
DATABASE_URL=XXX # DB root access (SECRET)
JWT_SECRET=XXX # JWT signing key (SECRET)
SECRET_KEY_BASE=XXX # GoTrue crypto key (SECRET)
API_EXTERNAL_URL=http://localhost:8080

SUPABASE_URL=http://auth:9999

SUPABASE_ANON_KEY=XXX # Public project key (still private)

# =========================================================================
# POSTGRES DATABASE (Service: db)
# =========================================================================

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=supabase
POSTGRES_USER=postgres
POSTGRES_PASSWORD=XXX # DB root password
POSTGRES_INITDB_ARGS=--auth-host=scram-sha-256

# =========================================================================
# SUPABASE AUTH (Service: auth)
# =========================================================================

GOTRUE_DB_HOST=db
GOTRUE_DB_PORT=5432
GOTRUE_DB_DRIVER=postgres
GOTRUE_DB_USER=postgres
GOTRUE_DB_PASSWORD=XXX # DB password
GOTRUE_DB_NAME=supabase
GOTRUE_DB_DATABASE_URL=XXX # DB connection string
GOTRUE_DB_NAMESPACE=auth
GOTRUE_JWT_SECRET=XXX # JWT signing key
GOTRUE_SITE_URL=http://localhost:5173

GOTRUE_EXTERNAL_URL=http://localhost:9999

# =========================================================================
# SUPABASE STORAGE (Service: storage)
# =========================================================================

STORAGE_PORT=5000
STORAGE_DATABASE_URL=XXX # DB access
PGRST_JWT_SECRET=XXX # PostgREST signing key
ANON_KEY=XXX # JWT public anon key
SERVICE_KEY=XXX # ROOT SERVICE ROLE KEY
STORAGE_BACKEND=file
FILE_STORAGE_BACKEND_PATH=/var/lib/storage
STORAGE_EXTERNAL_URL=http://localhost:5000

# =========================================================================
# SUPABASE REALTIME (Service: realtime)
# =========================================================================

REALTIME_PORT=4000
APP_NAME=realtime
HOSTNAME=localhost
DB_HOST=db
DB_NAME=supabase
DB_USER=postgres
DB_PASSWORD=XXX # DB password
DB_PORT=5432
ERL_NODE_NAME=realtime@localhost
REPLICATION_MODE=RLS
REPLICATION_SLOT_NAME=supabase_realtime_rcv
RLIMIT_NOFILE=1048576

# =========================================================================
# SUPABASE STUDIO / DASHBOARD
# =========================================================================

STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project

SUPABASE_PUBLIC_URL=http://localhost:8080

PG_META_CRYPTO_KEY=XXX # Metadata encryption key
ANON_KEY=XXX
SERVICE_ROLE_KEY=XXX
DASHBOARD_USERNAME=studio
DASHBOARD_PASSWORD=XXX # Studio admin password
OPENAI_API_KEY=XXX # Billing API key

# =========================================================================
# FRONTEND / VITE CONFIG
# =========================================================================

FRONTEND_PORT=5173
BACKEND_PORT=8000
VITE_DB_MODE=SUPABASE
VITE_BASE44_APP_ID=XXX # Private Base44 app ID
VITE_BASE44_BACKEND_URL=XXX # Private backend URL